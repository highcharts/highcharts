{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "nodenext",
        "noEmit": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "allowJs": true,
        "skipLibCheck": true,
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "~/*": ["./*"],
            "~code/*": ["../code/*"],
            "~ts/*": ["../ts/*"]
        }
    },
    "include": ["./**/*.ts", "./**/*.mts", "./**/*.js"]
}
