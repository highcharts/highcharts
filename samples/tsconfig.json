{
    "compilerOptions": {
        "downlevelIteration": true,
        "sourceMap": false,
        "noImplicitAny": true,
        "noImplicitThis": true,
        "strict": false,
        "stripInternal": true,
        "baseUrl": "../",
        "module": "es2022",
        "moduleDetection": "auto",
        "allowUmdGlobalAccess": true,
        "moduleResolution": "node",
        "target": "ES2022",
        "lib": [
            "dom",
            "ES2015",
            "ES2017.SharedMemory"
        ],
        "paths": {
            "highcharts": ["code/highcharts"],
            "highcharts/*": ["code/*"],
            "@highcharts/dashboards": ["code/dashboards/dashboards"],
            "@highcharts/dashboards/*": ["code/dashboards/dashboards/*"]
        },
        "types": [
            // disable node types
        ]
    },
    "files": [
        "tsglobal.d.ts",
    ],
    "references": [
        { "path": "./tsconfig.gantt.json" },
        { "path": "./tsconfig.highcharts.json" },
        { "path": "./tsconfig.maps.json" },
        { "path": "./tsconfig.stock.json" },
        { "path": "./tsconfig.unit-tests.json" }
    ]
}
